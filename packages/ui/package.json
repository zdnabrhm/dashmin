{
	"name": "@dashmin/ui",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm dlx @tailwindcss/cli -i ./src/style.css -o ./dist/style.css --watch",
		"build": "pnpm dlx @tailwindcss/cli -i ./src/style.css -o ./dist/style.css",
		"typecheck": "tsc --noEmit"
	},
	"exports": {
		"./style.css": "./dist/style.css",
		"./lib/*": "./src/lib/*.ts",
		"./components/*": "./src/components/*.tsx",
		"./hooks/*": "./src/hooks/*.ts"
	},
	"dependencies": {
		"@base-ui/react": "^1.2.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@hugeicons/core-free-icons": "^3.1.1",
		"@hugeicons/react": "^1.1.5",
		"@tailwindcss/cli": "^4.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"shadcn": "^3.8.5",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@types/node": "^25.3.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"globals": "^16.5.0",
		"typescript": "^5.9.3"
	}
}
