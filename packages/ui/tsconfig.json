{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"baseUrl": ".",
		"paths": {
			"@/ui/*": ["./src/*"]
		}
	},
	"include": ["src"]
}
